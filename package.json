{
  "name": "eslint-plugin-harlanzw",
  "type": "module",
  "version": "0.5.17",
  "packageManager": "pnpm@10.32.0",
  "description": "Harlan's opinionated ESLint rules",
  "author": "Harlan Wilton <harlan@harlanzw.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://github.com/harlan-zw/eslint-plugin-harlanzw#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harlan-zw/eslint-plugin-harlanzw.git"
  },
  "bugs": "https://github.com/harlan-zw/eslint-plugin-harlanzw/issues",
  "keywords": [
    "eslint-plugin"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "pnpm run dev && eslint . --fix",
    "release": "pnpm build && bumpp",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "dependencies": {
    "@eslint/plugin-kit": "^0.6.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@antfu/ni": "^28.3.0",
    "@antfu/utils": "^9.3.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.4.0",
    "@typescript-eslint/typescript-estree": "^8.57.0",
    "@typescript-eslint/utils": "^8.57.0",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "eslint-vitest-rule-tester": "^3.1.0",
    "jsonc-eslint-parser": "^3.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue": "^3.5.30"
  },
  "resolutions": {
    "eslint-plugin-harlanzw": "workspace:*"
  }
}
