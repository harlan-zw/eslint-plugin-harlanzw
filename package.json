{
  "name": "eslint-plugin-harlanzw",
  "type": "module",
  "version": "0.13.0",
  "packageManager": "pnpm@11.1.1",
  "description": "Harlan's opinionated ESLint rules",
  "author": "Harlan Wilton <harlan@harlanzw.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/harlan-zw",
  "homepage": "https://github.com/harlan-zw/eslint-plugin-harlanzw#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harlan-zw/eslint-plugin-harlanzw.git"
  },
  "bugs": "https://github.com/harlan-zw/eslint-plugin-harlanzw/issues",
  "keywords": [
    "eslint-plugin"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "pnpm run dev && eslint . --fix",
    "release": "pnpm build && bumpp --commit 'chore: release v%s' --tag 'v%s' --push --all",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "dependencies": {
    "@eslint/plugin-kit": "^0.7.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@antfu/ni": "^30.1.0",
    "@antfu/utils": "^9.3.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.7.0",
    "@typescript-eslint/parser": "^8.59.3",
    "@typescript-eslint/typescript-estree": "^8.59.3",
    "@typescript-eslint/utils": "^8.59.3",
    "bumpp": "^11.1.0",
    "eslint": "^10.3.0",
    "eslint-vitest-rule-tester": "^3.1.0",
    "jsonc-eslint-parser": "^3.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.0",
    "yaml-eslint-parser": "^2.0.0"
  },
  "resolutions": {
    "eslint-plugin-harlanzw": "workspace:*"
  }
}
